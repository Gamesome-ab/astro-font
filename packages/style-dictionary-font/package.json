{
	"name": "@gamesome/style-dictionary-font",
	"version": "0.0.1",
	"description": "Style Dictionary format and action for generating optimized @font-face CSS with fallback scaling",
	"main": "./dist/style-dictionary-font.js",
	"module": "./dist/style-dictionary-font.mjs",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/style-dictionary-font.mjs",
			"require": "./dist/style-dictionary-font.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "vite build --watch",
		"build": "vite build",
		"test": "vitest run"
	},
	"dependencies": {
		"@gamesome/core-font": "workspace:*"
	},
	"peerDependencies": {
		"style-dictionary": "^4.0.0"
	},
	"devDependencies": {
		"style-dictionary": "^4.0.0",
		"typescript": "5.2.2",
		"vite": "4.5.0",
		"vite-plugin-dts": "3.6.3",
		"vitest": "0.34.6"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Gamesome-ab/astro-font.git"
	},
	"keywords": [
		"style-dictionary",
		"font",
		"font-face",
		"fallback",
		"optimisation",
		"optimization",
		"performance",
		"cls"
	],
	"bugs": {
		"url": "https://github.com/Gamesome-ab/astro-font/issues"
	},
	"homepage": "https://github.com/Gamesome-ab/astro-font#readme",
	"author": "Johan Svensson",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	}
}
